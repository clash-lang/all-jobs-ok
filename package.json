{
  "name": "all-ok",
  "version": "1.0.0",
  "description": "GitHub Action that checks the 'all' job depends on all other jobs in a workflow",
  "private": true,
  "license": "BSD-2-Clause",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node20 --outfile=dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format-check": "prettier --check ."
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "esbuild": "^0.25.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
